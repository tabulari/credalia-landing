# Credalia Landing — environment contract
# Copy to `.env.local` for development: `cp .env.example .env.local`
#
# These placeholder values let the page render in DEVELOPMENT. A PRODUCTION
# build (`next build`) will FAIL until every ⚠️ value below is replaced with the
# real one — enforced by the guard in src/lib/config.ts. Do not commit real
# secrets; `.env.local` is gitignored.

# ──── Company Identity ────

# ⚠️ Brand display name (nav, footer, legal pages, WhatsApp messages)
NEXT_PUBLIC_BRAND_NAME=Credalia

# ⚠️ Company legal name (footer, JSON-LD)
NEXT_PUBLIC_COMPANY_LEGAL_NAME=Credalia S.A.S.

# ⚠️ NIT (tax ID, shown in footer)
NEXT_PUBLIC_COMPANY_NIT=XXX.XXX.XXX-X

# ⚠️ Registered address (footer, JSON-LD)
NEXT_PUBLIC_COMPANY_ADDRESS=Domicilio pendiente, Colombia

# ──── Contact ────

# ⚠️ WhatsApp Business line (digits only, country code first)
NEXT_PUBLIC_WHATSAPP_PHONE=573001234567

# ⚠️ Contact phone (with country code, shown in footer)
NEXT_PUBLIC_CONTACT_PHONE=+573001234567

# Contact email (footer)
NEXT_PUBLIC_CONTACT_EMAIL=hola@credalia.co

# Contact hours (footer)
NEXT_PUBLIC_CONTACT_HOURS=Lun a Vie, 8:00–18:00

# ──── Social Profiles ────

# ⚠️ Social profile URLs (confirm real handles before launch)
NEXT_PUBLIC_SOCIAL_FACEBOOK=https://facebook.com/credalia
NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/credalia
NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/company/credalia
NEXT_PUBLIC_SOCIAL_YOUTUBE=https://www.youtube.com/@credalia

# ──── Site ────

# ⚠️ Canonical site origin (absolute — needed for OG images, canonical, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://www.credalia.co

# ──── Regulator ────

# Compliance gate. Set to "true" ONLY after legal confirms supervision status;
# gates the regulator seal + "Entidad vigilada" copy.
NEXT_PUBLIC_REGULATOR_VERIFIED=false

# Regulator display name (shown when REGULATOR_VERIFIED=true)
NEXT_PUBLIC_REGULATOR_NAME=Superintendencia Financiera de Colombia

# Short regulator name (used in badges)
NEXT_PUBLIC_REGULATOR_SHORT_NAME=Superfinanciera

# ──── Credit Product (interim — will come from Credalia dashboard API) ────

# Monthly interest rate as decimal (0.026 = 2.6% monthly)
NEXT_PUBLIC_CREDIT_MONTHLY_RATE=0.026

# Eligibility: small-amount threshold (COP) — amounts below this can't use long terms
NEXT_PUBLIC_CREDIT_SMALL_AMOUNT_THRESHOLD=200000

# Eligibility: max term (months) for amounts below the small-amount threshold
NEXT_PUBLIC_CREDIT_SMALL_AMOUNT_MAX_TERM=18

# Eligibility: high-amount threshold (COP) — amounts above this require a minimum term
NEXT_PUBLIC_CREDIT_HIGH_AMOUNT_THRESHOLD=800000

# Eligibility: min term (months) for amounts above the high-amount threshold
NEXT_PUBLIC_CREDIT_HIGH_AMOUNT_MIN_TERM=6

# ──── Simulator ────

# Min loan amount (COP)
NEXT_PUBLIC_SIM_AMOUNT_MIN=50000

# Max loan amount (COP)
NEXT_PUBLIC_SIM_AMOUNT_MAX=1000000

# Slider step (COP)
NEXT_PUBLIC_SIM_AMOUNT_STEP=10000

# ± Stepper jump size (COP)
NEXT_PUBLIC_SIM_AMOUNT_STEP_BIG=50000

# Default loan amount when simulator first renders (COP)
NEXT_PUBLIC_SIM_DEFAULT_AMOUNT=500000

# Default term when simulator first renders (months)
NEXT_PUBLIC_SIM_DEFAULT_TERM=12

# Available term options, comma-separated (months)
NEXT_PUBLIC_SIM_TERM_OPTIONS=3,6,9,12,18,24

# ──── Application Form ────

# Bank names for the bank dropdown, comma-separated
NEXT_PUBLIC_APPLICATION_BANKS=Bancolombia,Davivienda,BBVA,Banco de Bogotá,Nequi,Daviplata

# Employment types for the employment dropdown, comma-separated
NEXT_PUBLIC_APPLICATION_EMPLOYMENT_TYPES=Empleado,Independiente,Pensionado

# ──── Brand Colors (used for manifest, theme-color, JSON-LD) ────

NEXT_PUBLIC_COLOR_NAVY=#0d2a5e
NEXT_PUBLIC_COLOR_ORANGE=#f5601b
NEXT_PUBLIC_COLOR_GREEN=#1e9e55

# ──── Backend ────

# ⚠️ Server-only: real application submit endpoint (app/api/application forwards here)
APPLICATION_ENDPOINT=https://example.invalid/applications

# ⚠️ Server-only: shared secret sent as X-Landing-Api-Key when forwarding to
# Core's POST /api/v1/intake/web-lead. Must match Core's CORE_LANDING_API_KEY.
# See docs/specs/secrets-and-keys.md #7 in credalia-core.
LANDING_API_KEY=

# ⚠️ Public: Core's base API URL. The simulator fetches
# GET /api/v1/sessions/rates-config from this base on mount to get live
# rate/threshold config; falls back to the static NEXT_PUBLIC_CREDIT_*
# values above if the request fails. No secret required (public read).
NEXT_PUBLIC_CORE_API_URL=https://example.invalid

# ──── Analytics (optional) ────

# Google Tag Manager container ID (e.g. GTM-XXXXXXX). If empty, no GTM script loads.
# NEXT_PUBLIC_GTM_ID=

# ──── CI / Preview ────

# CI/preview escape hatch: allow a production build with placeholders still set
# (for axe/Lighthouse against a non-live build). Never set this in real prod.
# NEXT_PUBLIC_CREDALIA_ALLOW_PLACEHOLDERS=false
